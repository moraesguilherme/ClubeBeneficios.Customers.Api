    private static string? BuildReason(params string?[] parts)
    {
        var values = parts
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim())
            .ToArray();

        return values.Length == 0 ? null : string.Join(" | ", values);
    }

    
    public async Task<ConvertPartnerCustomerResponse?> ConvertToCustomerAsync(
        Guid partnerCustomerId,
        ConvertPartnerCustomerRequest request,
        CancellationToken cancellationToken = default)
    {
        var detail = await _repository.GetByIdAsync(partnerCustomerId, cancellationToken);
        if (detail is null)
        {
            return null;
        }

        var alreadyConvertedAt = GetNullableDateTime(detail, "ConvertedToFullRegistrationAt");
        if (alreadyConvertedAt.HasValue)
        {
            return new ConvertPartnerCustomerResponse
            {
                PartnerCustomerId = partnerCustomerId,
                CustomerId = null,
                ConvertedAt = alreadyConvertedAt.Value,
                CustomerCreated = false,
                CustomerUpdated = false,
                Message = "Partner customer ja estava convertido."
            };
        }

        var createCustomerRequest = new CreateCustomerAdminRequest();

        CopyIfPropertyExists(detail, createCustomerRequest, "UserId", "UserId");
        CopyIfPropertyExists(detail, createCustomerRequest, "FullName", "FullName");
        CopyIfPropertyExists(detail, createCustomerRequest, "Document", "Document");
        CopyIfPropertyExists(detail, createCustomerRequest, "Email", "Email");
        CopyIfPropertyExists(detail, createCustomerRequest, "Phone", "Phone");
        CopyIfPropertyExists(detail, createCustomerRequest, "BirthDate", "BirthDate");
        CopyIfPropertyExists(detail, createCustomerRequest, "NotesSummary", "NotesSummary");

        SetIfPropertyExists(createCustomerRequest, "OriginType", "partner_conversion");

        if (request is not null)
        {
            if (!string.IsNullOrWhiteSpace(request.TargetCustomerStatus))
            {
                SetIfPropertyExists(createCustomerRequest, "Status", request.TargetCustomerStatus);
            }

            if (request.AcceptsMarketing.HasValue)
            {
                SetIfPropertyExists(createCustomerRequest, "AcceptsMarketing", request.AcceptsMarketing.Value);
            }

            if (!string.IsNullOrWhiteSpace(request.Notes))
            {
                SetIfPropertyExists(createCustomerRequest, "NotesSummary", request.Notes);
            }
        }

        await _customerRepository.CreateAsync(createCustomerRequest, GetCurrentUserId(), cancellationToken);

        var updatePartnerCustomerRequest = BuildPartnerCustomerUpdateRequest(detail, request);
        await _repository.UpdateAsync(partnerCustomerId, updatePartnerCustomerRequest, GetCurrentUserId(), cancellationToken);

        return new ConvertPartnerCustomerResponse
        {
            PartnerCustomerId = partnerCustomerId,
            CustomerId = null,
            ConvertedAt = DateTime.UtcNow,
            CustomerCreated = true,
            CustomerUpdated = false,
            Message = "Conversao executada. CustomerId nao e retornado pelo repository atual."
        };
    }

    private UpdatePartnerCustomerAdminRequest BuildPartnerCustomerUpdateRequest(
        object detail,
        ConvertPartnerCustomerRequest request)
    {
        var updateRequest = new UpdatePartnerCustomerAdminRequest();

        CopyIfPropertyExists(detail, updateRequest, "UserId", "UserId");
        CopyIfPropertyExists(detail, updateRequest, "PartnerId", "PartnerId");
        CopyIfPropertyExists(detail, updateRequest, "AccessCodeId", "AccessCodeId");
        CopyIfPropertyExists(detail, updateRequest, "FullName", "FullName");
        CopyIfPropertyExists(detail, updateRequest, "Email", "Email");
        CopyIfPropertyExists(detail, updateRequest, "Phone", "Phone");
        CopyIfPropertyExists(detail, updateRequest, "Document", "Document");
        CopyIfPropertyExists(detail, updateRequest, "BirthDate", "BirthDate");
        CopyIfPropertyExists(detail, updateRequest, "OriginType", "OriginType");
        CopyIfPropertyExists(detail, updateRequest, "OriginChannel", "OriginChannel");
        CopyIfPropertyExists(detail, updateRequest, "RegistrationStage", "RegistrationStage");
        CopyIfPropertyExists(detail, updateRequest, "Status", "Status");
        CopyIfPropertyExists(detail, updateRequest, "BenefitsDashboardUnlockedAt", "BenefitsDashboardUnlockedAt");
        CopyIfPropertyExists(detail, updateRequest, "FirstAccessAt", "FirstAccessAt");
        CopyIfPropertyExists(detail, updateRequest, "LastAccessAt", "LastAccessAt");
        CopyIfPropertyExists(detail, updateRequest, "AcceptedTermsAt", "AcceptedTermsAt");
        CopyIfPropertyExists(detail, updateRequest, "AcceptedPrivacyPolicyAt", "AcceptedPrivacyPolicyAt");
        CopyIfPropertyExists(detail, updateRequest, "NotesSummary", "NotesSummary");

        SetIfPropertyExists(updateRequest, "ConvertedToFullRegistrationAt", DateTime.UtcNow);

        if (request is not null && !string.IsNullOrWhiteSpace(request.Notes))
        {
            SetIfPropertyExists(updateRequest, "NotesSummary", request.Notes);
        }

        return updateRequest;
    }

    private static void CopyIfPropertyExists(object source, object target, string sourcePropertyName, string targetPropertyName)
    {
        if (source is null || target is null)
        {
            return;
        }

        var sourceProperty = source.GetType().GetProperty(sourcePropertyName);
        var targetProperty = target.GetType().GetProperty(targetPropertyName);

        if (sourceProperty is null || targetProperty is null || !targetProperty.CanWrite)
        {
            return;
        }

        var sourceValue = sourceProperty.GetValue(source);
        if (sourceValue is null)
        {
            return;
        }

        var targetType = Nullable.GetUnderlyingType(targetProperty.PropertyType) ?? targetProperty.PropertyType;
        var sourceType = sourceValue.GetType();

        if (targetType.IsAssignableFrom(sourceType))
        {
            targetProperty.SetValue(target, sourceValue);
            return;
        }

        try
        {
            var convertedValue = Convert.ChangeType(sourceValue, targetType);
            targetProperty.SetValue(target, convertedValue);
        }
        catch
        {
        }
    }

    private static void SetIfPropertyExists(object target, string propertyName, object value)
    {
        if (target is null)
        {
            return;
        }

        var property = target.GetType().GetProperty(propertyName);
        if (property is null || !property.CanWrite)
        {
            return;
        }

        if (value is null)
        {
            property.SetValue(target, null);
            return;
        }

        var targetType = Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType;
        var valueType = value.GetType();

        if (targetType.IsAssignableFrom(valueType))
        {
            property.SetValue(target, value);
            return;
        }

        try
        {
            var convertedValue = Convert.ChangeType(value, targetType);
            property.SetValue(target, convertedValue);
        }
        catch
        {
        }
    }

    private static DateTime? GetNullableDateTime(object source, string propertyName)
    {
        if (source is null)
        {
            return null;
        }

        var property = source.GetType().GetProperty(propertyName);
        if (property is null)
        {
            return null;
        }

        var value = property.GetValue(source);
        if (value is null)
        {
            return null;
        }

        if (value is DateTime dateTime)
        {
            return dateTime;
        }

        if (value is DateTime? nullableDateTime)
        {
            return nullableDateTime;
        }

        if (DateTime.TryParse(value.ToString(), out var parsed))
        {
            return parsed;
        }

        return null;
    }

    private Guid? GetCurrentUserId() => Guid.TryParse(_userContext.UserId, out var value) ? value : null;
